# Required: LLM API Key
LLM_API_KEY=your_anthropic_or_openrouter_key_here

# Optional: Change LLM provider (default: Anthropic)
# For OpenRouter: https://openrouter.ai/api/v1
# For local Ollama: http://localhost:11434/v1
LLM_BASE_URL=https://api.anthropic.com/v1

# Models (default: claude-sonnet-4-6)
ELIRA_MODEL=claude-sonnet-4-6
AGENT_MODEL=claude-sonnet-4-6

# Optional: Telegram notifications
# Create a bot via @BotFather, get your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: Web search — enables Alba to do real research
# Get Tavily key at https://tavily.com
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Optional: Daily digest email via AgentMail
# Get key at https://agentmail.to
AGENTMAIL_API_KEY=
DIGEST_EMAIL=

# Optional: Timezone for digest schedule (default: UTC)
# Examples: America/New_York, Europe/London, Asia/Tokyo
TZ=UTC

# Optional: API token to protect /api/* routes
# Leave blank for local-only use. Set a random string when exposing to a network.
API_TOKEN=

# Optional: Lightpanda headless browser — gives Alba full JS-rendered page content
# 9-11x faster and 16x less memory than Chrome. Install:
#   curl -fsSL https://pkg.lightpanda.io/install.sh | bash
# Then run alongside the server:
#   ./lightpanda serve --host 127.0.0.1 --port 9222
LIGHTPANDA_URL=

# Web server port (default: 3000)
PORT=3000
